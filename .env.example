# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME=AI Research Assistant API
# Controls behavior: "development" enables debug mode, verbose errors
# "production" tightens security, disables debug traces
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Prefix for all API routes → /api/v1/health, /api/v1/documents, etc.
API_V1_PREFIX=/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI
# ─────────────────────────────────────────────────────────────────────────────
# Get this from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# CORS (who is allowed to call this API from a browser)
# JSON array of allowed frontend origins
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]


# postgresql+asyncpg:// tells SQLAlchemy to use asyncpg as the driver
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_research_db

# Connection pool: max open connections to PostgreSQL at any time
# Rule of thumb: (2 × CPU cores) + 1 for a web server workload
DB_POOL_SIZE=10

# Extra connections allowed during bursts (e.g., traffic spikes)
DB_MAX_OVERFLOW=20

# Seconds a connection can sit idle in the pool before being recycled
# Keep below PostgreSQL's idle_in_transaction_session_timeout
DB_POOL_RECYCLE=3600